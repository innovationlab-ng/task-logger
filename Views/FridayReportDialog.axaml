<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TaskLoggerApp.ViewModels"
        x:Class="TaskLoggerApp.Views.FridayReportDialog"
        x:DataType="vm:FridayReportDialogViewModel"
        Title="Weekly Report Reminder"
        Width="400" Height="210"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/avalonia-logo.ico">

    <StackPanel Margin="28 24 28 24" Spacing="16">

        <StackPanel Spacing="4">
            <TextBlock Text="📅 It’s Friday!"
                       FontSize="17" FontWeight="SemiBold"/>
            <TextBlock Text="Time to export this week’s task report before the weekend."
                       Opacity="0.65" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,8,*">
            <Button Grid.Column="0"
                    Content="Open Reports"
                    Classes="accent"
                    Command="{Binding YesCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
            <Button Grid.Column="2"
                    Content="Not now"
                    Command="{Binding NoCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
        </Grid>

    </StackPanel>

</Window>
