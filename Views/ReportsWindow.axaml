<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TaskLoggerApp.ViewModels"
        x:Class="TaskLoggerApp.Views.ReportsWindow"
        x:DataType="vm:ReportsViewModel"
        Title="Reports"
        Width="440" Height="460"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/avalonia-logo.ico">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="28 20 28 20">

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Reports"
                       FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Select a week to export a consolidated CSV."
                       Opacity="0.6"
                       TextWrapping="Wrap"
                       Margin="0 2 0 0"/>
        </StackPanel>

        <!-- ── Week list ─────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ListBox ItemsSource="{Binding WeekKeys}"
                     SelectedItem="{Binding SelectedWeekKey}"
                     Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{Binding}" Padding="4 2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ── Buttons ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,8,*,8,*,8,*" Margin="0 12 0 0">
            <Button Grid.Column="0"
                    Content="↺  Refresh"
                    Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
            <Button Grid.Column="2"
                    Content="Export"
                    Command="{Binding ExportCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
            <Button Grid.Column="4"
                    Content="📂 Open Folder"
                    Command="{Binding OpenFolderCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
            <Button Grid.Column="6"
                    Content="Close"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>
        </Grid>

        <!-- ── Status message ────────────────────────────────────────────── -->
        <!-- Success: green, shown when export succeeded -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="Green"
                   TextWrapping="Wrap"
                   Margin="0 10 0 0"
                   IsVisible="{Binding !IsStatusError}"
                   IsEnabled="{Binding StatusMessage,
                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="!IsStatusError"/>
                    <Binding Path="StatusMessage"
                             Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                </MultiBinding>
            </TextBlock.IsVisible>
        </TextBlock>
        <!-- Error: red, shown when export failed -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0 10 0 0">
            <TextBlock.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="IsStatusError"/>
                    <Binding Path="StatusMessage"
                             Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                </MultiBinding>
            </TextBlock.IsVisible>
        </TextBlock>

    </Grid>

</Window>
